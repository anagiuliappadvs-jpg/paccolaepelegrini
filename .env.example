# ==========================================================================
# MODELO de configuracao. COPIE este arquivo para um chamado ".env"
# (sem o ".example") e preencha com os SEUS dados.
#
# O arquivo ".env" NUNCA vai pro GitHub (esta no .gitignore).
# No GitHub Actions, estes valores entram como "Secrets", nao neste arquivo.
# ==========================================================================

# Token de longa duracao da Instagram Graph API (gerado no Meta for Developers)
IG_ACCESS_TOKEN=cole_aqui_o_token

# ID da conta Instagram Business (ig-user-id) - so numeros
IG_USER_ID=cole_aqui_o_id

# ID e Segredo do app (usados so para RENOVAR o token automaticamente)
IG_APP_ID=cole_aqui_o_id_do_app
IG_APP_SECRET=cole_aqui_o_segredo_do_app

# (Opcional) versao da Graph API. Deixe assim se nao souber.
IG_API_VERSION=v22.0

# (Opcional, para a Fase 6 - sugestoes por IA) chave da API da Anthropic
ANTHROPIC_API_KEY=
